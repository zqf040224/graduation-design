# 系统配置
DEBUG=False
PORT=5003
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5003
COOKIE_SECURE=True
CACHE_BACKEND=memory
EMBEDDING_DEVICE=cpu

# 存储配置
# 默认 local：继续使用项目目录下的 uploads / knowledge_base / outputs。
# 公司 NAS 测试时，先把 NAS 共享目录挂载到应用服务器，再设置：
# STORAGE_BACKEND=nas
# NAS_MOUNT_PATH=/mnt/knowledge-agent
STORAGE_BACKEND=local
STORAGE_ROOT=
NAS_MOUNT_PATH=
UPLOADS_DIR=
KNOWLEDGE_BASE_DIR=
OUTPUTS_DIR=
KNOWLEDGE_SOURCE_DIR=
INGESTION_MANIFEST_DB=
SPREADSHEET_DB_PATH=
ADMIN_BACKUP_DIR=

# 管理员默认账号（首次启动时自动创建）
ADMIN_DEFAULT_PASSWORD=admin123

# JWT 密钥（生产环境请生成随机字符串）
JWT_SECRET=generate-a-random-secret-here

# API密钥
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
BOCHA_API_KEY=sk-your-bocha-key-here
